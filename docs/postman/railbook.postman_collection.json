{
  "info": {
    "name": "RailBook API",
    "description": "Railway ticket booking API with concurrency handling",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "scheduleId", "value": "" },
    { "key": "seatId", "value": "" },
    { "key": "trainId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "auth": { "type": "noauth" }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"full_name\": \"Test User\",\n  \"phone\": \"01234567890\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.access_token);",
                  "  pm.collectionVariables.set('refreshToken', json.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Trains",
      "item": [
        {
          "name": "List Trains",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trains",
            "auth": { "type": "noauth" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.length > 0) {",
                  "    pm.collectionVariables.set('trainId', json[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Schedules",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trains/{{trainId}}/schedules",
            "auth": { "type": "noauth" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  if (json.length > 0) {",
                  "    pm.collectionVariables.set('scheduleId', json[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Seat Availability",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/trains/schedules/{{scheduleId}}/seats",
            "auth": { "type": "noauth" }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var json = pm.response.json();",
                  "  var available = json.seats.find(s => !s.booking_status);",
                  "  if (available) {",
                  "    pm.collectionVariables.set('seatId', available.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schedule_id\": \"{{scheduleId}}\",\n  \"seat_id\": \"{{seatId}}\",\n  \"idempotency_key\": \"{{$guid}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set('bookingId', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Pay Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings/{{bookingId}}/pay",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"{{$guid}}\"\n}"
            }
          }
        },
        {
          "name": "List My Bookings",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "Get Booking",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/bookings/{{bookingId}}"
          }
        },
        {
          "name": "Refund Booking",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/bookings/{{bookingId}}/refund"
          }
        }
      ]
    },
    {
      "name": "Demo",
      "item": [
        {
          "name": "Race Condition",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/demo/race-condition",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"schedule_id\": \"{{scheduleId}}\",\n  \"seat_id\": \"{{seatId}}\"\n}"
            }
          }
        },
        {
          "name": "Get Config",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/demo/config",
            "auth": { "type": "noauth" }
          }
        },
        {
          "name": "Update Config",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/demo/config",
            "auth": { "type": "noauth" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"failure_rate\": 0.3,\n  \"latency_ms\": 200\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "All Bookings",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/bookings?limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "bookings"],
              "query": [{ "key": "limit", "value": "20" }]
            }
          }
        },
        {
          "name": "Occupancy",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/occupancy"
          }
        },
        {
          "name": "Audit Trail",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/audit"
          }
        }
      ]
    }
  ]
}
